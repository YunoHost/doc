#: docs/admin/12.webadmin.mdx:1
#, no-wrap
msgid "⭐ Webadmin interface"
msgstr "⭐ Webadmin arayüzü"

#. type: Plain text
#: docs/admin/12.webadmin.mdx:7
#, no-wrap
msgid "YunoHost has an administrator web interface. The other way to administrate your YunoHost install is through the [command line](/admin/command_line).\n"
msgstr ""
"YunoHost bir admin internet arayüzüne sahiptir. YunoHost yüklemenize yetki "
"vermenin diğer bir yolu ise [komut satırı](/admin/command_line) üzerinden "
"yüklemektir..\n"

#. type: Plain text
#: docs/admin/12.webadmin.mdx:9
#, no-wrap
msgid "The webadmin can be accessed at `https://yourdomain.tld/yunohost/admin` or using the local IP or global IP of your server (`https://1.2.3.4/yunohost/admin`)\n"
msgstr ""
"Webadmin `https://yourdomain.tld/yunohost/admin` alan adı üzerinden ya da "
"lokal IP adresi üzerinden ya da sunucunuzun açık IP adresi üzerinden "
"erişilebilir (`https://1.2.3.4/yunohost/admin`)\n"

#. type: Plain text
#: docs/admin/12.webadmin.mdx:10
#, no-wrap
msgid "<Figure caption=\"Screenshot of YunoHost webadmin\" src=\"/img/webadmin/webadmin.jpg\" />\n"
