#, no-wrap
msgid "OVH DNS config via API"
msgstr "OVH üzerinden API ile alan adı sunucu özelleştirmesi"

#. type: Yaml Front Matter Hash Value: title
#: docs/admin/05.get_started/10.providers/05.registrar/ovh/autodns.mdx:1
#, no-wrap
msgid "Obtaining an API key from OVH"
msgstr "OVH'den API anahtarı elde etmek"

#. type: Plain text
#: docs/admin/05.get_started/10.providers/05.registrar/ovh/autodns.mdx:7
#, no-wrap
msgid "This page is meant to guide you in obtaining an API key from OVH in order to configure YunoHost's automatic DNS configuration mecanism\n"
msgstr ""

#. type: Plain text
#: docs/admin/05.get_started/10.providers/05.registrar/ovh/autodns.mdx:13
#, no-wrap
msgid "1. Go to [the OVH token request page](https://eu.api.ovh.com/createToken/)\n"
msgstr ""

#. type: Plain text
#: docs/admin/05.get_started/10.providers/05.registrar/ovh/autodns.mdx:15
#, no-wrap
msgid "2. Fill the form with the required information as shown below:\n"
msgstr ""

#. type: Plain text
#: docs/admin/05.get_started/10.providers/05.registrar/ovh/autodns.mdx:26
#, no-wrap
msgid ""
"    - Account ID or email address: This is your usual OVH login\n"
"    - Password: This is your usual OVH password\n"
"    - Script Name: for example `YunoHost Auto DNS`\n"
"    - Script description: for example `YunoHost Auto DNS`\n"
"    - Validity: `Unlimited`\n"
"    - Rights: use the `+` button to add the following lines\n"
"      - `GET` : `/domain/zone/*`\n"
"      - `POST` : `/domain/zone/*`\n"
"      - `PUT` : `/domain/zone/*`\n"
"      - `DELETE` : `/domain/zone/*`\n"
msgstr ""

#. type: Plain text
#: docs/admin/05.get_started/10.providers/05.registrar/ovh/autodns.mdx:29
#, no-wrap
msgid "3. You will obtain three tokens (an application key, a secret application key, and a consumer key) which should be used in YunoHost's configuration\n"
msgstr ""
